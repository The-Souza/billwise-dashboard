generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model workspaces {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  owner_id    String    @db.Uuid
  is_personal Boolean   @default(false)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  owner           profiles            @relation("owned_workspaces", fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  members         workspace_members[]
  invites         workspace_invites[]
  accounts        accounts[]
  budgets         budgets[]
  recurring_rules recurring_rules[]

  @@schema("public")
}

model workspace_members {
  workspace_id String                @db.Uuid
  user_id      String                @db.Uuid
  role         workspace_member_role @default(member)
  joined_at    DateTime              @default(now()) @db.Timestamptz(6)

  workspace workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      profiles   @relation("workspace_memberships", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([workspace_id, user_id])
  @@index([user_id], map: "idx_workspace_members_user_id")
  @@schema("public")
}

model workspace_invites {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspace_id    String                  @db.Uuid
  invited_user_id String                  @db.Uuid
  invited_by      String                  @db.Uuid
  status          workspace_invite_status @default(pending)
  created_at      DateTime                @default(now()) @db.Timestamptz(6)
  expires_at      DateTime                @db.Timestamptz(6)

  workspace     workspaces      @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invited_user  profiles        @relation("received_invites", fields: [invited_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inviter       profiles        @relation("sent_invites", fields: [invited_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notifications notifications[]

  @@index([invited_user_id, status], map: "idx_workspace_invites_invited_user_status")
  @@schema("public")
}

model account_installments {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id         String    @db.Uuid
  installment_number Int
  total_installments Int
  due_date           DateTime  @db.Date
  amount             Decimal   @db.Decimal(12, 2)
  paid_at            DateTime? @db.Timestamptz(6)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  accounts           accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([account_id, installment_number])
  @@schema("public")
}

model accounts {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String                 @db.Uuid
  workspace_id         String                 @db.Uuid
  title                String
  year                 Int
  month                Int
  consumption          Decimal?               @db.Decimal(10, 2)
  days                 Int?
  amount               Decimal                @db.Decimal(10, 2)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  category_id          String?                @db.Uuid
  status               account_status?        @default(pending)
  description          String?
  due_date             DateTime?              @db.Date
  paid_at              DateTime?              @db.Timestamptz(6)
  recurring_rule_id    String?                @db.Uuid
  account_date         DateTime               @db.Date
  installment_group_id String?                @db.Uuid
  account_installments account_installments[]
  categories           categories?            @relation(fields: [category_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "accounts_category_fk")
  recurring_rules      recurring_rules?       @relation(fields: [recurring_rule_id], references: [id], onUpdate: NoAction, map: "accounts_recurring_rule_fkey")
  profiles             profiles               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspaces           workspaces             @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notifications        notifications[]

  @@index([category_id], map: "idx_accounts_category_id")
  @@index([due_date], map: "idx_accounts_due_date")
  @@index([status], map: "idx_accounts_status")
  @@index([user_id], map: "idx_accounts_user_id")
  @@index([workspace_id], map: "idx_accounts_workspace_id")
  @@index([account_date], map: "idx_accounts_account_date")
  @@schema("public")
}

model budgets {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String     @db.Uuid
  workspace_id String     @db.Uuid
  category_id  String     @db.Uuid
  year         Int
  month        Int
  limit_amount Decimal    @db.Decimal(12, 2)
  created_at   DateTime?  @default(now()) @db.Timestamptz(6)
  categories   categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles     profiles   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspaces   workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([workspace_id, category_id, year, month])
  @@schema("public")
}

model categories {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  type            category_type
  is_utility      Boolean?          @default(false)
  icon            String?
  accounts        accounts[]
  budgets         budgets[]
  recurring_rules recurring_rules[]

  @@index([type], map: "idx_categories_type")
  @@schema("public")
}

model profiles {
  id                 String              @id @db.Uuid
  name               String
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  avatar_url         String?
  notification_prefs Json?
  accounts           accounts[]
  budgets            budgets[]
  notifications      notifications[]
  recurring_rules    recurring_rules[]
  owned_workspaces   workspaces[]        @relation("owned_workspaces")
  workspace_memberships workspace_members[] @relation("workspace_memberships")
  received_invites   workspace_invites[] @relation("received_invites")
  sent_invites       workspace_invites[] @relation("sent_invites")

  @@schema("public")
}

model recurring_rules {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String     @db.Uuid
  workspace_id      String     @db.Uuid
  category_id       String     @db.Uuid
  title             String
  amount            Decimal    @db.Decimal(12, 2)
  frequency         String
  start_date        DateTime   @db.Date
  end_date          DateTime?  @db.Date
  created_at        DateTime?  @default(now()) @db.Timestamptz(6)
  recurrence_months Int?
  accounts          accounts[]
  categories        categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles          profiles   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspaces        workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model notifications {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String             @db.Uuid
  title               String
  body                String?
  type                String
  account_id          String?            @db.Uuid
  workspace_invite_id String?            @db.Uuid
  read_at             DateTime?          @db.Timestamptz(6)
  created_at          DateTime?          @default(now()) @db.Timestamptz(6)
  accounts            accounts?          @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspace_invites   workspace_invites? @relation(fields: [workspace_invite_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  profiles            profiles           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([read_at], map: "idx_notifications_read_at")
  @@index([user_id], map: "idx_notifications_user_id")
  @@schema("public")
}

enum account_status {
  pending
  paid
  overdue

  @@schema("public")
}

enum category_type {
  expense
  income

  @@schema("public")
}

enum workspace_member_role {
  owner
  member

  @@schema("public")
}

enum workspace_invite_status {
  pending
  accepted
  declined

  @@schema("public")
}
